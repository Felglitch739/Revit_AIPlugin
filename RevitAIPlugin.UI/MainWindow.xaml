<Window x:Class="RevitAIPlugin.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Revit AI Assistant" Height="600" Width="450"
        Background="#1E1E2E" ResizeMode="CanResize" MinWidth="350" MinHeight="400">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="🤖 Revit AI Assistant"
                       Foreground="#CDD6F4" FontSize="18" FontWeight="Bold"/>
            <TextBlock Text="Escribe lo que quieres hacer en Revit"
                       Foreground="#6C7086" FontSize="11" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Chat messages -->
        <Border Grid.Row="1" Background="#181825" CornerRadius="8" Padding="8">
            <ScrollViewer x:Name="scrollViewer" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="messagesPanel">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,4" Padding="10,8" CornerRadius="8"
                                    Background="{Binding Background}"
                                    HorizontalAlignment="{Binding Alignment}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Sender}"
                                               Foreground="#6C7086" FontSize="10"
                                               Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding Text}"
                                               Foreground="{Binding TextColor}"
                                               FontSize="13" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Input area -->
        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#313244" CornerRadius="8" Padding="2">
                <TextBox x:Name="txtInput"
         Background="Transparent" Foreground="#CDD6F4"
         BorderThickness="0" FontSize="13"
         Padding="8,6" VerticalContentAlignment="Center"
         TextWrapping="Wrap" MaxHeight="80"
         AcceptsReturn="False"
         KeyDown="TxtInput_KeyDown"/>
                         
            </Border>

            <Button x:Name="btnEnviar" Grid.Column="1"
                    Content="Enviar" Margin="8,0,0,0"
                    Background="#89B4FA" Foreground="#1E1E2E"
                    FontWeight="Bold" FontSize="13"
                    Padding="16,8" BorderThickness="0"
                    Cursor="Hand" Click="BtnEnviar_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Grid>
</Window>